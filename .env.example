# Tushare API token. 申请地址：https://tushare.pro/user/token
TUSHARE_TOKEN=

# Optional: 限制 tushare 调用频率（默认 200 次/分钟）
# TUSHARE_RATE_LIMIT_PER_MIN=200

# Optional: 邮件通知（163 SMTP 授权码）
# SENDER_EMAIL=
# SENDER_PASSWORD=
# RECEIVER_EMAILS=
# SMTP_SERVER=smtp.163.com
# SMTP_PORT=465
# SMTP_USE_SSL=true

# Optional: 微信公众号草稿/发布
# WECHAT_MP_APPID=
# WECHAT_MP_SECRET=
# WECHAT_MP_AUTHOR=持志堂
# WECHAT_MP_THUMB_MEDIA_ID=
# WECHAT_MP_COVER_IMAGE=
# WECHAT_MP_CONTENT_SOURCE_URL=
# WECHAT_MP_AUTO_PUBLISH=false
# WECHAT_MP_AUTO_MASS_SEND=false
